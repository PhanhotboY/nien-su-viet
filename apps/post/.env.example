# Environment Configuration Example
# Copy this file to .env and update the values for your development environment

# ============================================================================
# Application Options
# ============================================================================
APP_SERVICE_NAME=postservice
APP_DELIVERY_TYPE=http

# ============================================================================
# GRPC Server Configuration
# ============================================================================
GRPC_NAME=postservice
GRPC_PORT=6005
GRPC_HOST=localhost
GRPC_DEVELOPMENT=true

# ============================================================================
# Logging Configuration
# ============================================================================
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug
LOG_TYPE=0
LOG_CALLER_ENABLED=false

# ============================================================================
# MongoDB Configuration
# ============================================================================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=admin
MONGODB_PASSWORD=admin
MONGODB_DATABASE=posts_service
MONGODB_USE_AUTH=true

# ============================================================================
# RabbitMQ Configuration
# ============================================================================
RABBITMQ_AUTO_START=true
RABBITMQ_RECONNECTING=true
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOSTNAME=localhost
RABBITMQ_PORT=5672
RABBITMQ_HTTP_PORT=15672

# ============================================================================
# Distributed Tracing Configuration
# ============================================================================
TRACING_ENABLE=true
TRACING_SERVICE_NAME=posts-service
TRACING_INSTRUMENTATION_NAME=io.opentelemetry.traces.posts-service
TRACING_ID=1
TRACING_USE_STDOUT=false
TRACING_ALWAYS_ON_SAMPLER=true

# ============================================================================
# Jaeger Exporter Configuration
# ============================================================================
JAEGER_OTLP_ENDPOINT=localhost:4320
JAEGER_ENABLED=true

# ============================================================================
# Zipkin Exporter Configuration
# ============================================================================
ZIPKIN_URL=http://localhost:9411/api/v2/spans

# ============================================================================
# Uptrace Provider Configuration (Optional)
# ============================================================================
# Set UPTRACE_ENABLED=true to enable Uptrace tracing
UPTRACE_ENABLED=false
UPTRACE_OTLP_ENDPOINT=otlp.uptrace.dev:4317
UPTRACE_DSN=https://<token>@uptrace.dev/<project_id>

# ============================================================================
# Elastic APM Provider Configuration (Optional)
# ============================================================================
# Set ELASTIC_APM_ENABLED=true to enable Elastic APM
ELASTIC_APM_ENABLED=false
ELASTIC_APM_OTLP_ENDPOINT=host.docker.internal:4317
ELASTIC_APM_SECRET_TOKEN=<your-elastic-apm-secret-token>

# ============================================================================
# Metrics Configuration
# ============================================================================
METRICS_ROUTE_PATH=/metrics
METRICS_SERVICE_NAME=posts-service
METRICS_INSTRUMENTATION_NAME=io.opentelemetry.metrics.posts-service
