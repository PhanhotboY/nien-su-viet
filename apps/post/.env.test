POST_SERVER_ENV=test

# ============================================================================
# Application Options
# ============================================================================
POST_SERVER_SERVICE_NAME=post-service

# ============================================================================
# GRPC Server Configuration
# ============================================================================
POST_GRPC_NAME=post-grpc-server
POST_GRPC_PORT=6005
POST_GRPC_HOST=0.0.0.0
POST_GRPC_DEVELOPMENT=true

# ============================================================================
# Logging Configuration
# ============================================================================
# Levels: trace, debug, info, warn, error, fatal
POST_LOG_LEVEL=debug
POST_LOG_TYPE=0
POST_LOG_CALLER_ENABLED=false

# ============================================================================
# RabbitMQ Configuration
# ============================================================================
POST_RMQ_AUTOSTART=true
POST_RMQ_RECONNECTING=true
POST_RMQ_USERNAME=nsv_rmq_user
POST_RMQ_PASSWORD=secure_password
POST_RMQ_HOSTNAME=localhost
POST_RMQ_PORT=5672
POST_RMQ_HTTP_PORT=15672

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POST_PG_HOST=localhost
POST_PG_PORT=5432
POST_PG_USERNAME=nsv_post_user
POST_PG_PASSWORD=secure_password
POST_PG_DATABASE=nsv_post_db
POST_PG_LOG_LEVEL=4
POST_PG_SSL_MODE=false

# ============================================================================
# Redis Configuration
# ============================================================================
POST_REDIS_HOST=localhost
POST_REDIS_PORT=6379
POST_REDIS_USERNAME=""
POST_REDIS_PASSWORD=""
POST_REDIS_DATABASE=0
POST_REDIS_POOL_SIZE=300
POST_REDIS_ENABLE_TRACING=true
